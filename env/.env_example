# ── Мой налог (lknpd.nalog.ru) ─────────────────────────────────────────────
NALOG_INN=
NALOG_PASSWORD=

# ── База данных (PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=

# ── Поведение воркера ───────────────────────────────────────────────────────
# Интервал между циклами (минуты)
TIMER=60

# Задержка между отправками чеков (секунды)
SEND_DELAY=10
